{
  "tests": [
    {
      "name": "Login with missing credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Укажите логин и пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "notexist", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный логин или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Logout without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "logout"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    }
  ]
}